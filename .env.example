# MongoDB
MONGODB_URI=mongodb://localhost:27017/tripgo

# NextAuth
NEXTAUTH_SECRET=your-super-secret-key-change-in-production
NEXTAUTH_URL=http://localhost:3000

# Anthropic Claude API
ANTHROPIC_API_KEY=your-anthropic-api-key

# OpenRouter (cloud LLM — free tier available at https://openrouter.ai)
# Used if ANTHROPIC_API_KEY is not set. Free models: qwen/qwen3-235b-a22b:free
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=qwen/qwen3.6-plus:free

# OpenRouteService (free routing - https://openrouteservice.org/dev/#/signup)
OPENROUTE_API_KEY=your-openroute-api-key

# Unsplash API (free - https://unsplash.com/developers)
UNSPLASH_ACCESS_KEY=your-unsplash-access-key
